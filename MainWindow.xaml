                                <TextBlock Margin="0" Text="{Binding Text, ElementName=txtStr1, Converter={StaticResource UpperCaseConverter}}"/>
                                <TextBlock>, Lower case is</TextBlock>
                                <TextBlock Margin="0" Text="{Binding Text, ElementName=txtStr1, Converter={StaticResource LowerCaseConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="TextTruncate">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Name="txtStr2" Width="150" Text="a fox jumps over the lazy dog"></TextBox>
