<Window x:Class="IceSky.WpfConverters.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IceSky.WpfConverters.Sample"
        xmlns:conv="clr-namespace:IceSky.WpfConverters.Converters;assembly=IceSky.WpfConverters"
        xmlns:t="clr-namespace:IceSky.WpfConverters;assembly=IceSky.WpfConverters"
        xmlns:ext="clr-namespace:IceSky.Extensions;assembly=IceSky.Extensions"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen"
        Title="Samples for IceSky.WpfConverters" Height="450" Width="800" MinWidth="600" MinHeight="400" Icon="/logo.ico">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IceSky.WpfConverters;component/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="GroupBox" >
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="2"/>
            </Style>
            <conv:XamlSwitchConverter x:Key="StatusSwitchConverter" DefaultValue="未知状态">
                <conv:XamlSwitchConverter.Cases>
                    <conv:XamlSwitchCase When="Active" Then="激活"/>
                    <conv:XamlSwitchCase When="Inactive" Then="未激活"/>
                    <conv:XamlSwitchCase When="Pending" Then="待处理"/>
                    <conv:XamlSwitchCase When="Deleted" Then="已删除"/>
                </conv:XamlSwitchConverter.Cases>
            </conv:XamlSwitchConverter>
            <conv:XamlSwitchConverter x:Key="OrderStatusStyleConverter">
                <conv:XamlSwitchConverter.Cases>
                    <conv:XamlSwitchCase When="Pending">
                        <conv:XamlSwitchCase.Then>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E1DC81"/>
                                <Setter Property="BorderBrush" Value="#FF9800"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Style>
                        </conv:XamlSwitchCase.Then>
                    </conv:XamlSwitchCase>
                    <conv:XamlSwitchCase When="Approved">
                        <conv:XamlSwitchCase.Then>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#C8DFAD"/>
                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Style>
                        </conv:XamlSwitchCase.Then>
                    </conv:XamlSwitchCase>
                    <conv:XamlSwitchCase When="Shipped">
                        <conv:XamlSwitchCase.Then>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#85B7DF"/>
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Style>
                        </conv:XamlSwitchCase.Then>
                    </conv:XamlSwitchCase>
                    <conv:XamlSwitchCase When="Delivered">
                        <conv:XamlSwitchCase.Then>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#98DF9D"/>
                                <Setter Property="BorderBrush" Value="#8BC34A"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Style>
                        </conv:XamlSwitchCase.Then>
                    </conv:XamlSwitchCase>
                    <conv:XamlSwitchCase When="Cancelled">
                        <conv:XamlSwitchCase.Then>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E36F80"/>
                                <Setter Property="BorderBrush" Value="#F44336"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Opacity" Value="0.7"/>
                            </Style>
                        </conv:XamlSwitchCase.Then>
                    </conv:XamlSwitchCase>
                </conv:XamlSwitchConverter.Cases>
                <conv:XamlSwitchConverter.DefaultValue>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#F5F5F5"/>
                        <Setter Property="BorderBrush" Value="#9E9E9E"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </conv:XamlSwitchConverter.DefaultValue>
            </conv:XamlSwitchConverter>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <TabControl>
            <TabControl.Resources>
                <Style TargetType="Border" x:Key="bdTest">
                    <Setter Property="Width" Value="100"/>
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="Background" Value="DodgerBlue"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
                <Style TargetType="CheckBox" >
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="5"/>
                </Style>
                <Style TargetType="TextBox" >
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Padding" Value="2"/>
                    <Setter Property="Width" Value="70"/>
                </Style>
                <Style TargetType="ComboBox" >
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="5"/>
                </Style>
                <Style TargetType="Slider" >
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Width" Value="60"/>
                    <Setter Property="IsSnapToTickEnabled" Value="True"/>
                    <Setter Property="TickFrequency" Value="1"/>
                    <Setter Property="AutoToolTipPlacement" Value="TopLeft"/>
                </Style>
                <Style TargetType="TextBlock" >
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                </Style>
            </TabControl.Resources>
            <TabItem Header="Number">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="NegatvieNumber">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="tbNumber" Margin="5" Text="10"/>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber, Converter={StaticResource NegatvieNumberConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="RoundNumber">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="tbNumber1" Margin="5" Text="10"/>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber1, Converter={StaticResource Round2DecimalsConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="NumberToBool">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="tbNumber2" Margin="5" Text="10"/>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber2, Converter={StaticResource NumberToBoolConverter}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="NumberToRatioInt">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="tbNumber3" Margin="5" Text="10"/>
                                <TextBlock>Double is:</TextBlock>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber3, Converter={StaticResource NumberToDoubleIntConverter}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="RangeMap 0-100 → 100-300">
                            <StackPanel Orientation="Horizontal">
                                <Slider x:Name="SliderRange" Width="100" Minimum="0" Maximum="100" Margin="5" TickFrequency="1" IsSnapToTickEnabled="True" AutoToolTipPlacement="TopLeft"/>
                                <Border x:Name="bdRange" Height="20" Background="Blue" HorizontalAlignment="Left"
                                        Width="{Binding Value, ElementName=SliderRange, Converter={conv:RangeMapConverter FromMin=0,FromMax=100,ToMin=100,ToMax=300}}">
                                    <TextBlock Text="{Binding ElementName=bdRange,Path=Width}" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="PercentInRange 0~1000">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="tbNumber4" Margin="5" Text="10"/>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber4, Converter={conv:PercentConverter Maximum=1000},StringFormat={}{0} %}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="InRange -100~100">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="tbNumber5" Margin="5" Text="10"/>
                                <TextBlock>in [-100, 100] is</TextBlock>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber5, Converter={conv:InRangeConverter Min=-100,Max=100}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"/>
                                <TextBlock>, Inverted is</TextBlock>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber5, Converter={conv:InRangeConverter Min=-100,Max=100,IsReversed=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"/>
                                <TextBlock>, in (-100, 100] is</TextBlock>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber5, Converter={conv:InRangeConverter Min=-100,Max=100,IncludeMin=False}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"/>
                                <TextBlock>, in [-100, 100) is</TextBlock>
                                <TextBlock Text="{Binding Text, ElementName=tbNumber5, Converter={conv:InRangeConverter Min=-100,Max=100,IncludeMax=False}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Format">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtNumber" Width="100" Text="123.456" Margin="5"/>
                                <TextBlock>Currency format is</TextBlock>
                                <TextBlock Margin="5" Text="{Binding Text, ElementName=txtNumber, Converter={conv:NumberFormatConverter Format={}{0:C2}}}"/>
                                <TextBlock>format with ‘000.000’ is</TextBlock>
                                <TextBlock Margin="5" Text="{Binding Text, ElementName=txtNumber, Converter={conv:NumberFormatConverter Format={}{0:000.000}}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="IntToString">
                            <StackPanel Orientation="Horizontal">
                                <Slider x:Name="sldIsTest" Minimum="0" Maximum="5" TickFrequency="1"/>
                                <TextBlock>Text:</TextBlock>
                                <TextBlock Text="{Binding ElementName=sldIsTest,Path=Value,Converter={conv:IntToStringConverter Source='Unknow,Active,Inactive,Pending,Deleted',Default=Out of range}}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="FileSize">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Name="txtNumber1" Width="120" Text="20480"></TextBox>
                                <TextBlock>File size is</TextBlock>
                                <TextBlock Margin="0" Text="{Binding Text, ElementName=txtNumber1, Converter={StaticResource FileSizeConverter}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="InterpolateNumber">
                            <StackPanel Orientation="Horizontal">
                                <ListBox Height="100" Width="80" Margin="5" ItemsSource="{Binding Converter={conv:InterpolateNumberConverter Start=0, End=100, Count=5}}">
                                </ListBox>
                                <ListBox Height="100" Width="80" Margin="5" ItemsSource="{Binding Converter={conv:InterpolateNumberConverter Start=10, Step=5, Count=5}}">
                                </ListBox>
                                <ListBox Height="100" Width="80" Margin="5" ItemsSource="{Binding Converter={conv:InterpolateNumberConverter End=50, Step=2.5, Count=5}}">
                                </ListBox>
                                <ListBox Height="100" Width="80" Margin="5" ItemsSource="{Binding Converter={conv:InterpolateNumberConverter Start=0, End=-10, Step=-3}}">
                                </ListBox>
                                <ListBox Height="100" Width="80" Margin="5" ItemsSource="{Binding Converter={conv:InterpolateNumberConverter Start=0, End=-10, Step=-2.8, ClampToBounds=True}}">
                                </ListBox>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Bool">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="InvertBool">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="chkBool" Content="切换选中"/>
                                <TextBlock Text="{Binding ElementName=chkBool,Path=IsChecked,Converter={conv:InvertBoolConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="BoolToString">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="chkSex" Content="切换性别" IsChecked="True"/>
                                    <TextBlock Text="{Binding ElementName=chkSex,Path=IsChecked,Converter={conv:BoolToObjectConverter TrueValue=Man, FalseValue=Woman}}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="chkState" Content="切换状态" IsChecked="True" IsThreeState="True"/>
                                    <TextBlock Text="{Binding ElementName=chkState,Path=IsChecked,Converter={conv:BoolToObjectConverter TrueValue=运行, FalseValue=停止, NullValue=未知}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="BoolToVisible">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="chkVisible" Content="切换可见"/>
                                <Border Style="{StaticResource bdTest}" Width="110" Visibility="{Binding IsChecked, ElementName=chkVisible, Converter={StaticResource BoolToVisibleConverter}}">
                                    <TextBlock>Default</TextBlock>
                                </Border>
                                <Border Style="{StaticResource bdTest}" Width="110" Background="HotPink" Visibility="{Binding IsChecked, ElementName=chkVisible, Converter={StaticResource InvertBoolToVisibleConverter}}">
                                    <TextBlock>IsInverted=True</TextBlock>
                                </Border>
                                <Border Style="{StaticResource bdTest}" Width="110" Background="Orange" Visibility="{Binding IsChecked, ElementName=chkVisible, Converter={StaticResource FalseToHiddenConverter}}">
                                    <TextBlock>UseHidden=True</TextBlock>
                                </Border>
                                <Border Style="{StaticResource bdTest}" Background="Green"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="NullOrEmpty">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="tbEmptyBool" Width="100"></TextBox>
                                <CheckBox IsChecked="{Binding ElementName=tbEmptyBool,Path=Text,Converter={StaticResource IsNullOrEmptyConverter}}" IsEnabled="False">IsEmpty</CheckBox>
                                <CheckBox IsChecked="{Binding ElementName=tbEmptyBool,Path=Text,Converter={StaticResource InvertedNullOrEmptyConverter}}" IsEnabled="False">IsNotEmpty</CheckBox>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="BoolToColor">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="ChkColor" Content="切换颜色"/>
                                <Border Style="{StaticResource bdTest}" Background="{Binding IsChecked, ElementName=ChkColor, Converter={StaticResource BoolToColorConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="CompareTo">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc1"></TextBox>
                                    <TextBlock> > 10 is</TextBlock>
                                    <ComboBox Name="cbCompOpt" ItemsSource="{Binding Source={x:Type conv:CompareOperator}, Converter={conv:EnumToListConverter}}" Visibility="Collapsed"/>
                                    <TextBlock Margin="0" Text="{Binding ElementName=tbCompareSrc1,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=Greater}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc1,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=Greater,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc2"></TextBox>
                                    <TextBlock> ≥ 10 is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc2,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=GreaterOrEqual}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc2,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=GreaterOrEqual,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc3"></TextBox>
                                    <TextBlock Text="&lt; 10 is"></TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc3,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=Less}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc3,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=Less,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc4"></TextBox>
                                    <TextBlock> ≤ 10 is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc4,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=LessOrEqual}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc4,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=LessOrEqual,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc5"></TextBox>
                                    <TextBlock Text="= 10 is"></TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc5,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=Equal}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc5,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=Equal,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc6"></TextBox>
                                    <TextBlock> ≠ 10 is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc6,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=NotEqual}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc6,Path=Text,Converter={conv:CompareToConverter TargetValue=10,Operator=NotEqual,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc7"></TextBox>
                                    <TextBlock Text="Starts with 'a' is"></TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc7,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=StartsWith}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc7,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=StartsWith,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, IgnoreCase is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc7,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=StartsWith,IgnoreCase=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc8"></TextBox>
                                    <TextBlock> Ends with 'a' is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc8,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=EndsWith}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc8,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=EndsWith,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, IgnoreCase is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc8,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=EndsWith,IgnoreCase=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc9"></TextBox>
                                    <TextBlock> Contains 'a' is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc9,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=Contains}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc9,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=Contains,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, IgnoreCase is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc9,Path=Text,Converter={conv:CompareToConverter TargetValue=a,Operator=Contains,IgnoreCase=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc10"></TextBox>
                                    <TextBlock> in "12, ab, at" is</TextBlock>
                                    <TextBlock Margin="0" Text="{Binding ElementName=tbCompareSrc10,Path=Text,Converter={conv:CompareToConverter TargetValue='12, ab, at',Operator=In}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc10,Path=Text,Converter={conv:CompareToConverter TargetValue='12, ab, at',Operator=In,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, IgnoreCase is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc10,Path=Text,Converter={conv:CompareToConverter TargetValue='12, ab, at',Operator=In,IgnoreCase=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="tbCompareSrc11"></TextBox>
                                    <TextBlock> not in "12, ab, at" is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc11,Path=Text,Converter={conv:CompareToConverter TargetValue='12, ab, at',Operator=NotIn}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, Inverted is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc11,Path=Text,Converter={conv:CompareToConverter TargetValue='12, ab, at',Operator=NotIn,IsInverted=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                    <TextBlock>, IgnoreCase is</TextBlock>
                                    <TextBlock Text="{Binding ElementName=tbCompareSrc11,Path=Text,Converter={conv:CompareToConverter TargetValue='12, ab, at',Operator=NotIn,IgnoreCase=True}}" Foreground="{Binding RelativeSource={RelativeSource Mode=Self},Path=Text,Converter={StaticResource BoolToColorConverter}}"></TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="MultiLogic">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="Chk1">条件1</CheckBox>
                                    <CheckBox x:Name="Chk2">条件2</CheckBox>
                                    <CheckBox x:Name="Chk3">条件3</CheckBox>
                                    <Button Content="全部选中可用" Padding="8 4" Margin="5">
                                        <Button.IsEnabled>
                                            <MultiBinding Converter="{conv:MultiLogicConverter}">
                                                <Binding Path="IsChecked" ElementName="Chk1"/>
                                                <Binding Path="IsChecked" ElementName="Chk2"/>
                                                <Binding Path="IsChecked" ElementName="Chk3"/>
                                            </MultiBinding>
                                        </Button.IsEnabled>
                                    </Button>
                                </StackPanel>
                                <Border HorizontalAlignment="Stretch" BorderThickness="0 1 0 0" BorderBrush="#2222" Margin="5"/>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="chkOr1">条件1</CheckBox>
                                    <CheckBox x:Name="chkOr2">条件2</CheckBox>
                                    <CheckBox x:Name="chkOr3">条件3</CheckBox>
                                    <Button Content="任意选中可用" Padding="8 4" Margin="5">
                                        <Button.IsEnabled>
                                            <MultiBinding Converter="{conv:MultiLogicConverter UseOr=True}">
                                                <Binding Path="IsChecked" ElementName="chkOr1"/>
                                                <Binding Path="IsChecked" ElementName="chkOr2"/>
                                                <Binding Path="IsChecked" ElementName="chkOr3"/>
                                            </MultiBinding>
                                        </Button.IsEnabled>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="String">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Format">
