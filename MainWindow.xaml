                                    <TextBlock Text="{Binding Value, ElementName=sldMath, Converter={conv:MethodConverter TargetType={x:Type sys:Math},MethodName=Sin},StringFormat=0.000}"/>
                                    <TextBlock>, Math.Cos is</TextBlock>
                                    <TextBlock Text="{Binding Value, ElementName=sldMath, Converter={conv:MethodConverter TargetType={x:Type sys:Math},MethodName=Cos},StringFormat=0.000}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Extension">
