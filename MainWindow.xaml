                                    <TextBlock Text="{Binding Text, ElementName=txtMathExtension2, Converter={conv:MethodConverter TargetType={x:Type sys:Math},MethodName=Round,ParameterStr=2}}"/>
                                    <TextBlock>, Math.Clamp to 10~50 is</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtMathExtension2, Converter={conv:MethodConverter TargetType={x:Type sys:Math},MethodName=Clamp,ParameterStr='10,50'}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Slider x:Name="sldMath" Width="100" Minimum="0" Maximum="180" Margin="5" TickFrequency="1"/>
