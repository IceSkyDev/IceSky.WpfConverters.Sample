                                <TextBlock Margin="0" Text="{Binding Text, ElementName=txtStr2, Converter={StaticResource Max20LengthConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Mask">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtMaskStr" Width="100" Text="123456789" Margin="5"/>
                                <TextBlock>Mask default is</TextBlock>
                                <TextBlock Margin="0" Text="{Binding Text, ElementName=txtMaskStr, Converter={StaticResource StringMaskConverter}}"/>
                                <TextBlock>, Use '----' mask start is</TextBlock>
                                <TextBlock Margin="0" Text="{Binding Text, ElementName=txtMaskStr, Converter={conv:MaskFormatterConverter MaskPattern=----,UnmaskedStart=0}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="StringToList (Use ',' to separate items)">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtListStr" Width="140" Text="1,2,3" Margin="5"/>
                                <ComboBox SelectedIndex="0" Width="80" ItemsSource="{Binding Text, ElementName=txtListStr, Converter={conv:StringToListConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="StringToDictionary (item format is key=value,)">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtDictStr" Width="140" Text="a=1,b=2,c=3" Margin="5"/>
                                <ComboBox SelectedIndex="0" Name="cbDict" Width="80" ItemsSource="{Binding Text, ElementName=txtDictStr, Converter={conv:StringToDictionaryConverter}}" DisplayMemberPath="Key" SelectedValuePath="Value"/>
                                <TextBlock Text="{Binding ElementName=cbDict,Path=SelectedValue}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Object">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="EmptyToInvisible">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtObjTest" Text="EmptyToInvisible" Width="120"/>
                                <Button x:Name="btnObj" Content="Submit" Padding="8 2" VerticalAlignment="Center" Visibility="{Binding Text, ElementName=txtObjTest, Converter={StaticResource NullOrEmptyToHiddenConverter}}"/>
                                <Border Style="{StaticResource bdTest}" Margin="5 0" Height="24" Visibility="{Binding ElementName=btnObj,Path=Visibility,Converter={StaticResource InvertVisibilityConverter}}">
                                    <TextBlock Foreground="White">InvertVisibility</TextBlock>
                                </Border>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="EmptyToObject">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtObjTest1" Text="EmptyToObject" Width="120"/>
                                <TextBlock>Text:</TextBlock>
                                <TextBlock Text="{Binding ElementName=txtObjTest1,Path=Text,Converter={conv:NullOrEmptyToObjectConverter EmptyValue=is empty}}" 
                                           Foreground="{Binding ElementName=txtObjTest1,Path=Text,Converter={conv:NullOrEmptyToObjectConverter EmptyValue=Red, NonEmptyValue=Green}}"
                                           FontWeight="{Binding ElementName=txtObjTest1,Path=Text,Converter={conv:NullOrEmptyToObjectConverter EmptyValue=Bold,NonEmptyValue=Normal}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="EqualsToBool">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtObjTest2" Text="0" Width="120"/>
                                    <TextBlock> =0 is:</TextBlock>
                                    <TextBlock Margin="0" Text="{Binding ElementName=txtObjTest2,Path=Text,Converter={StaticResource IsZeroConverter}}"/>
                                    <TextBlock Margin="20 0 5 0"> !=0 is:</TextBlock>
                                    <TextBlock Margin="0" Text="{Binding ElementName=txtObjTest2,Path=Text,Converter={StaticResource NotZeroConverter}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Name="cbObj" Margin="5" SelectedIndex="0" ItemsSource="{Binding Source={x:Type local:TestEnum}, Converter={StaticResource EnumNameToListConverter}}"/>
                                    <TextBlock> selected index =1 is:</TextBlock>
                                    <TextBlock Margin="0" Text="{Binding ElementName=cbObj,Path=SelectedIndex,Converter={conv:EqualsToBoolConverter TargetValue={t:Int 1}}}"/>
                                    <TextBlock Margin="20 0 5 0"> !=2 is:</TextBlock>
                                    <TextBlock Margin="0" Text="{Binding ElementName=cbObj,Path=SelectedIndex,Converter={conv:EqualsToBoolConverter TargetValue={t:Int 2},IsInverted=True}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="SwitchCase">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Name="cbSwitches" Width="90" SelectedIndex="0" ItemsSource="{Binding Converter={conv:StringToListConverter Source='Unknow,Active,Inactive,Pending,Deleted'}}"/>
                                    <TextBlock>Result is:</TextBlock>
                                    <TextBlock Text="{Binding ElementName=cbSwitches,Path=Text,Converter={StaticResource StatusSwitchConverter}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Name="cbSwitches1" Width="90" SelectedIndex="0" ItemsSource="{Binding Converter={conv:StringToListConverter Source='Unknow,Pending,Approved,Shipped,Delivered,Cancelled'}}"/>
                                    <TextBlock>Result is:</TextBlock>
                                    <Border Width="30" Height="30" CornerRadius="20" Style="{Binding ElementName=cbSwitches1,Path=Text,Converter={StaticResource OrderStatusStyleConverter}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Name="cbSwitches2" Width="90" SelectedIndex="0" ItemsSource="{Binding Converter={conv:StringToListConverter Source='0,1,2,3,4,5'}}"/>
                                    <TextBlock>Result is:</TextBlock>
                                    <TextBlock Text="{Binding ElementName=cbSwitches2,Path=Text,Converter={conv:ValueMapConverter Mapping='1=⏳,2=✅,3=🚚,4=📦,5=❌', DefaultValue=-}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="EnumToList">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>UseDescription=False</TextBlock>
                                    <ComboBox Margin="5" SelectedIndex="0" ItemsSource="{Binding Source={x:Type local:TestEnum}, Converter={conv:EnumToListConverter}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>UseDescription=True</TextBlock>
                                    <ComboBox Margin="5" SelectedIndex="0" ItemsSource="{Binding Source={x:Type local:TestEnum}, Converter={conv:EnumToListConverter UseDescription=True, ExcludeValue='0,2'}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="EnumToDict">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>UseDescription=False</TextBlock>
                                    <ComboBox Name="cbEnum1" Margin="5" SelectedIndex="0" ItemsSource="{Binding Source={x:Type local:TestEnum}, Converter={conv:EnumToDictionaryConverter}}" DisplayMemberPath="Value" SelectedValuePath="Key"/>
                                    <TextBlock Text="{Binding ElementName=cbEnum1,Path=SelectedValue}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>UseDescription=True</TextBlock>
                                    <ComboBox Name="cbEnum2" Margin="5" SelectedIndex="0" ItemsSource="{Binding Source={x:Type local:TestEnum}, Converter={conv:EnumToDictionaryConverter UseDescription=True}}" DisplayMemberPath="Value" SelectedValuePath="Key"/>
                                    <TextBlock Text="{Binding ElementName=cbEnum2,Path=SelectedValue}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Color">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="StringToBrush">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtColor" Text="#FF3366" Width="100"/>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Text, ElementName=txtColor, Converter={StaticResource ColorAutoConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="ColorToTuple">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtRgbHslColor" Text="#FF3366" Width="100"/>
                                <TextBlock Text="{Binding ElementName=txtRgbHslColor,Path=Text,Converter={StaticResource Color2RgbConverter},StringFormat=RGB:{0}}"/>
                                <TextBlock Text="{Binding ElementName=txtRgbHslColor,Path=Text,Converter={StaticResource Color2HslConverter},StringFormat=HSL:{0}}"/>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Text, ElementName=txtRgbHslColor, Converter={StaticResource ColorAutoConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="HslToColor">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>H:</TextBlock>
                                <Slider x:Name="sldH" Minimum="0" Maximum="360"/>
                                <TextBlock>S:</TextBlock>
                                <Slider x:Name="sldS" Minimum="0" Maximum="100" Value="100"/>
                                <TextBlock>L:</TextBlock>
                                <Slider x:Name="sldL" Minimum="0" Maximum="100" Value="50"/>
                                <TextBlock>A:</TextBlock>
                                <Slider x:Name="sldA" Minimum="0" Maximum="100" Value="100"/>
                                <TextBlock x:Name="tbHSLRet" Width="80">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{conv:ValuesToColorConverter IsHsl=True}">
                                            <Binding ElementName="sldH" Path="Value"/>
                                            <Binding ElementName="sldS" Path="Value"/>
                                            <Binding ElementName="sldL" Path="Value"/>
                                            <Binding ElementName="sldA" Path="Value"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Text, ElementName=tbHSLRet, Converter={StaticResource ColorAutoConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="RgbToColor">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock>R:</TextBlock>
                                <Slider x:Name="sldR" Minimum="0" Maximum="255"/>
                                <TextBlock>G:</TextBlock>
                                <Slider x:Name="sldG" Minimum="0" Maximum="255"/>
                                <TextBlock>B:</TextBlock>
                                <Slider x:Name="sldB" Minimum="0" Maximum="255"/>
                                <TextBlock>A:</TextBlock>
                                <Slider x:Name="sldA1" Minimum="0" Maximum="100" Value="100"/>
                                <TextBlock x:Name="tbRGBRet" Width="80">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{conv:ValuesToColorConverter}">
                                            <Binding ElementName="sldR" Path="Value"/>
                                            <Binding ElementName="sldG" Path="Value"/>
                                            <Binding ElementName="sldB" Path="Value"/>
                                            <Binding ElementName="sldA1" Path="Value"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Text, ElementName=tbRGBRet, Converter={StaticResource ColorAutoConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="ValueToColor">
                            <StackPanel Orientation="Horizontal">
                                <Slider x:Name="sldValue" Value="0" Width="100" Minimum="0" Maximum="100"/>
                                <TextBlock>Use RGB is:</TextBlock>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Value, ElementName=sldValue, Converter={StaticResource DefaultValueToRangeRgbConverter}}"/>
                                <TextBlock>Use HSL is:</TextBlock>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Value, ElementName=sldValue, Converter={StaticResource DefaultValueToRangeHslConverter}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Brightness">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtBright" Text="#FF3366" Width="100"/>
                                <TextBlock>Ratio=0.2</TextBlock>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Text, ElementName=txtBright, Converter={conv:BrightnessConverter Factor=0.2}}"/>
                                <TextBlock>Ratio=0.5</TextBlock>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Text, ElementName=txtBright, Converter={StaticResource DefaultBrightnessConverter}}"/>
                                <TextBlock>Ratio=1</TextBlock>
                                <Border Style="{StaticResource bdTest}" Width="50" Background="{Binding Text, ElementName=txtBright, Converter={conv:BrightnessConverter Factor=1}}"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="InterpolateColor">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel>
                                    <TextBlock>10 colors from Red to Green</TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>RGB</TextBlock>
                                        <ItemsControl Width="50" Height="100" ItemsSource="{Binding Converter={conv:InterpolateColorConverter StartValue=Red,EndValue=Green,Count=10}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="50" Height="10" Background="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock>HSL</TextBlock>
                                        <ItemsControl Width="50" Height="100" ItemsSource="{Binding Converter={conv:InterpolateColorConverter StartValue=Red,EndValue=Green,Count=10,UseHsl=True}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="50" Height="10" Background="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                                <Border BorderThickness="1 0 0 0" BorderBrush="#3333" Margin="20 10"/>
                                <StackPanel>
                                    <TextBlock>20 colors from Blue to Orange</TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>RGB</TextBlock>
                                        <ItemsControl Width="50" Height="100" ItemsSource="{Binding Converter={conv:InterpolateColorConverter StartValue=Blue,EndValue=Orange,Count=20}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="50" Height="5" Background="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock>HSL</TextBlock>
                                        <ItemsControl Width="50" Height="100" ItemsSource="{Binding Converter={conv:InterpolateColorConverter StartValue=Blue,EndValue=Orange,Count=20,UseHsl=True}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="50" Height="5" Background="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Expression">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Arithmetic ">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Name="tbExpAritSrc" Text="0"></TextBox>
                                <TextBlock>+2 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpAritSrc,Path=Text,Converter={conv:ExpressionConverter Formula='#+2'}}"></TextBlock>
                                <TextBlock>, /4 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpAritSrc,Path=Text,Converter={conv:ExpressionConverter Formula='#/4'}}"></TextBlock>
                                <TextBlock>, %5 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpAritSrc,Path=Text,Converter={conv:ExpressionConverter Formula='#%5'}}"></TextBlock>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Compare">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Name="tbExpCompSrc" Text="0"></TextBox>
                                <TextBlock>>2 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpCompSrc,Path=Text,Converter={conv:ExpressionConverter Formula=#>2}}"></TextBlock>
                                <TextBlock>, &lt;=3 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpCompSrc,Path=Text,Converter={conv:ExpressionConverter Formula='# &lt;=3'}}"></TextBlock>
                                <TextBlock>, &lt;&gt;5 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpCompSrc,Path=Text,Converter={conv:ExpressionConverter Formula=# &lt;&gt;5}}"></TextBlock>
                                <TextBlock>, &gt;= 60 AND &lt;= 100 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpCompSrc,Path=Text,Converter={conv:ExpressionConverter Formula='# &gt;= 60 AND # &lt;= 100'}}"></TextBlock>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Logic">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Name="chkExpLogicSrc"></CheckBox>
                                <TextBlock>and true =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=chkExpLogicSrc,Path=IsChecked,Converter={conv:ExpressionConverter Formula=# and true}}"></TextBlock>
                                <TextBlock>, or false =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=chkExpLogicSrc,Path=IsChecked,Converter={conv:ExpressionConverter Formula=# or false}}"></TextBlock>
                                <TextBlock>, not =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=chkExpLogicSrc,Path=IsChecked,Converter={conv:ExpressionConverter Formula=not #}}"></TextBlock>
                                <TextBlock>, iif =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=chkExpLogicSrc,Path=IsChecked,Converter={conv:ExpressionConverter Formula='iif(#,\'yes\',\'no\')'}}"></TextBlock>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="StringOperation">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Name="tbExpSrc" Text="0"></TextBox>
                                <TextBlock>lenth =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpSrc,Path=Text,Converter={conv:ExpressionConverter Formula='len(\'#\')'}}"></TextBlock>
                                <TextBlock>, trim =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpSrc,Path=Text,Converter={conv:ExpressionConverter Formula='trim(\'#\')'}}"></TextBlock>
                                <TextBlock>, concat 'abc' =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpSrc,Path=Text,Converter={conv:ExpressionConverter Formula='#+\'abc\''}}"></TextBlock>
                                <TextBlock>, substring =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpSrc,Path=Text,Converter={conv:ExpressionConverter Formula='substring(\'#\',2,3)'}}"></TextBlock>
                                <TextBlock>, iif >5 =</TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=tbExpSrc,Path=Text,Converter={conv:ExpressionConverter Formula='iif(#>5,\'是\', \'否\')'}}"></TextBlock>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Method">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="EnumToTuple" Visibility="Collapsed">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>UseDescription=False</TextBlock>
                                    <ComboBox Name="cbEnum3" Margin="5" SelectedIndex="0" ItemsSource="{Binding Source={x:Type local:TestEnum}, Converter={conv:EnumToTupleConverter}}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" Margin="0"/>
                                                    <TextBlock Text="{Binding Item1}" Margin="0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Text="{Binding ElementName=cbEnum3,Path=SelectedValue}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>UseDescription=True</TextBlock>
                                    <ComboBox Name="cbEnum4" Margin="5" SelectedIndex="0" ItemsSource="{Binding Source={x:Type local:TestEnum}, Converter={conv:EnumToTupleConverter UseDescription=True}}"/>
                                    <TextBlock Text="{Binding ElementName=cbEnum4,Path=SelectedValue}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

