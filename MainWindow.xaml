                                <StackPanel HorizontalAlignment="Left">
                                    <DatePicker Name="dpDate" Width="100" Margin="5 2" HorizontalAlignment="Left" SelectedDate="2026-01-01"></DatePicker>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Standard format is</TextBlock>
                                        <TextBlock Margin="0" Text="{Binding SelectedDate, ElementName=dpDate, Converter={StaticResource StandardDateTimeConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Universal format is</TextBlock>
                                        <TextBlock Margin="0" Text="{Binding SelectedDate, ElementName=dpDate, Converter={conv:StringFormatConverter Format={}{0:u}}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Chinese format is</TextBlock>
                                        <TextBlock Margin="0" Text="{Binding SelectedDate, ElementName=dpDate, Converter={conv:StringFormatConverter Format={}{0:yyyy年MM月dd日 HH时mm分ss秒}}}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtStr" Width="100" Text="123.456" Margin="5"/>
