                                    <TextBlock Text="{Binding Text, ElementName=txtMethodStr1, Converter={conv:MethodConverter MethodName=ToUpper}}"/>
                                    <TextBlock>, ToLower is:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtMethodStr1, Converter={conv:MethodConverter MethodName=ToLower}}"/>
                                    <TextBlock>, Trim is:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtMethodStr1, Converter={conv:MethodConverter MethodName=Trim}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtMethodStr2" Width="100" Text="abc" Margin="5"/>
