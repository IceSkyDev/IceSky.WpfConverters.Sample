                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtExtension1" Width="100" Text="Hello,世界No.1" Margin="5"/>
                                    <TextBlock>ExtractUpper:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtExtension1, Converter={conv:MethodConverter TargetType={x:Type ext:StringExtensions},MethodName=ExtractUpper}}"/>
                                    <TextBlock>, ExtractDigits:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtExtension1, Converter={conv:MethodConverter TargetType={x:Type ext:StringExtensions},MethodName=ExtractDigits}}"/>
                                    <TextBlock>, ExtractChinese:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtExtension1, Converter={conv:MethodConverter TargetType={x:Type ext:StringExtensions},MethodName=ExtractChinese}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtExtension2" Width="100" Text="ab c" Margin="5"/>
                                    <TextBlock>ToProperCase is:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtExtension2, Converter={conv:MethodConverter TargetType={x:Type ext:StringExtensions},MethodName=ToProperCase}}"/>
                                    <TextBlock>, Repeat(2) is:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtExtension2, Converter={conv:MethodConverter TargetType={x:Type ext:StringExtensions},MethodName=Repeat,ParameterStr=2}}"/>
                                    <TextBlock>, GetCharCount is:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtExtension2, Converter={conv:MethodConverter TargetType={x:Type ext:StringExtensions},MethodName=GetCharCount}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Slider x:Name="sldExten" Width="100" Minimum="1" Maximum="100" Margin="5" TickFrequency="1"/>
                                    <TextBlock>ToChinese is</TextBlock>
                                    <TextBlock Text="{Binding Value, ElementName=sldExten, Converter={conv:MethodConverter TargetType={x:Type ext:NumberExtensions},MethodName=ToChineseNumber}}"/>
                                    <TextBlock> UpperCase </TextBlock>
                                    <TextBlock Text="{Binding Value, ElementName=sldExten, Converter={conv:MethodConverter TargetType={x:Type ext:NumberExtensions},MethodName=ToChineseNumber,ParameterStr=true}}"/>
                                    <TextBlock>, ToRoman is</TextBlock>
                                    <TextBlock Text="{Binding Value, ElementName=sldExten, Converter={conv:MethodConverter TargetType={x:Type ext:NumberExtensions},MethodName=ToRomanNumeral}}"/>
                                    <TextBlock>, IsPrime is</TextBlock>
                                    <TextBlock Text="{Binding Value, ElementName=sldExten, Converter={conv:MethodConverter TargetType={x:Type ext:NumberExtensions},MethodName=IsPrime}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="ChainMode">
                <ScrollViewer Padding="5" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Rounding &amp; Currency">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtChainNumber" Width="100" Text="123.456" Margin="5"/>
                                <TextBlock>Triple Rounding Currency is</TextBlock>
                                <TextBlock Margin="5" Text="{Binding Text, ElementName=txtNumber, Converter={conv:StringFormatConverter Format={}{0:C}, FromConverter={conv:NumberToRatioIntConverter Ratio=3}}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="InvertBool &amp; ToVisible">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="chkChainBool" Content="切换选中"/>
                                <Border Style="{StaticResource bdTest}" Visibility="{Binding IsChecked, ElementName=chkChainBool, Converter={conv:BoolToVisibleConverter FromConverter={conv:InvertBoolConverter}, UseHidden=True}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="StringToDictionary &amp; Switch">
                            <StackPanel Orientation="Horizontal">
                                <ComboBox Name="cbSwitches3" Width="90" SelectedIndex="0" ItemsSource="{Binding Converter={conv:StringToListConverter Source='0,1,2,3,4,5'}}"/>
                                <TextBlock>Result is:</TextBlock>
                                <TextBlock Text="{Binding ElementName=cbSwitches3,Path=Text,Converter={conv:SwitchConverter Cases={conv:ConverterProperty FromConverter={conv:StringToDictionaryConverter Source='1=⏳,2=✅,3=🚚,4=📦,5=❌'}}}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Extension Methods">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtChainExt" Width="100" Text="abcdefg" Margin="5"/>
                                    <TextBlock>Trim &amp; ToUpper is</TextBlock>
                                    <TextBlock Margin="5" Text="{Binding Text, ElementName=txtChainExt, Converter={conv:MethodConverter MethodName=ToUpper, FromConverter={conv:MethodConverter MethodName=Trim}}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Slider x:Name="sldChainExt" Width="100" Minimum="0" Maximum="360" Margin="5" TickFrequency="15"/>
                                    <TextBlock>ToRadians &amp; Sin is</TextBlock>
                                    <TextBlock Text="{Binding Value, ElementName=sldChainExt, Converter={conv:MethodConverter TargetType={x:Type sys:Math},MethodName=Sin, FromConverter={conv:MethodConverter TargetType={x:Type ext:NumberExtensions},MethodName=ToRadians}},StringFormat=0.0000}"/>
                                    <TextBlock>, ToRadians &amp; Cos is</TextBlock>
                                    <TextBlock Text="{Binding Value, ElementName=sldChainExt, Converter={conv:MethodConverter TargetType={x:Type sys:Math},MethodName=Cos, FromConverter={conv:MethodConverter TargetType={x:Type ext:NumberExtensions},MethodName=ToRadians}},StringFormat=0.0000}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        <Button BorderBrush="Transparent" Background="Transparent" x:Name="btnHelp" Foreground="Blue" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5 0">Help</Button>
    </Grid>
</Window>
