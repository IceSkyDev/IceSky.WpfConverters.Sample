                                    <TextBlock Margin="0" Text="{Binding Text, ElementName=txtStr, Converter={conv:StringFormatConverter Format='|{0,10}|'}}"/>
                                    <TextBlock>, Left align is</TextBlock>
                                    <TextBlock Margin="0" Text="{Binding Text, ElementName=txtStr, Converter={conv:StringFormatConverter Format='|{0,-10}|'}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Case">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Name="txtStr1" Width="100" Text="Hello"></TextBox>
