                                    <TextBlock Text="{Binding Text, ElementName=txtMathExtension1, Converter={conv:MethodConverter TargetType={x:Type sys:Math}, MethodName=Abs}}"/>
                                    <TextBlock>, Math.Log10 is</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtMathExtension1, Converter={conv:MethodConverter TargetType={x:Type sys:Math},MethodName=Log10},StringFormat=0.000}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtMathExtension2" Width="100" Text="12.345" Margin="5"/>
