                                    <TextBlock>, Remove(3) is:</TextBlock>
                                    <TextBlock Text="{Binding Text, ElementName=txtMethodStr2, Converter={conv:MethodConverter MethodName=Remove,ParameterStr=3}}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Math">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtMathExtension1" Width="100" Text="100" Margin="5"/>
